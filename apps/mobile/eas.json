{
  "cli": {
    "version": ">= 12.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "simulator": true
      },
      "android": {
        "buildType": "apk"
      },
      "env": {
        "NODE_ENV": "development",
        "REALCLAW_API_URL": "http://localhost:18789",
        "REALCLAW_WS_URL": "ws://localhost:18789/ws"
      }
    },
    "preview": {
      "distribution": "internal",
      "env": {
        "NODE_ENV": "staging",
        "REALCLAW_API_URL": "https://staging-api.realclaw.com",
        "REALCLAW_WS_URL": "wss://staging-api.realclaw.com/ws"
      }
    },
    "staging": {
      "distribution": "internal",
      "channel": "staging",
      "env": {
        "NODE_ENV": "staging",
        "REALCLAW_API_URL": "https://staging-api.realclaw.com",
        "REALCLAW_WS_URL": "wss://staging-api.realclaw.com/ws"
      }
    },
    "production": {
      "distribution": "store",
      "channel": "production",
      "ios": {
        "buildConfiguration": "Release"
      },
      "android": {
        "buildType": "app-bundle"
      },
      "env": {
        "NODE_ENV": "production",
        "REALCLAW_API_URL": "https://api.realclaw.com",
        "REALCLAW_WS_URL": "wss://api.realclaw.com/ws"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "appleId": "YOUR_APPLE_ID",
        "ascAppId": "YOUR_ASC_APP_ID",
        "appleTeamId": "YOUR_APPLE_TEAM_ID"
      },
      "android": {
        "serviceAccountKeyPath": "./google-services-key.json",
        "track": "production",
        "releaseStatus": "completed"
      }
    }
  }
}
