# Dev only — set to your Windows LAN IP so the phone can reach the local backend.
# Find it with: ipconfig (Windows) → "IPv4 Address" on your WiFi adapter.
# Leave unset (or as localhost) when running in the iOS Simulator / Android Emulator.
EXPO_PUBLIC_API_HOST=192.168.1.100

# ─── Payments (RevenueCat) ───
# Get these from the RevenueCat dashboard → Project Settings → API Keys.
# iOS key starts with "appl_", Android key starts with "goog_".
# Leave blank (or set EXPO_PUBLIC_BYPASS_PAYWALL=true) during Expo Go development —
# RevenueCat / in-app purchases only work in EAS native builds on a real device.
EXPO_PUBLIC_RC_API_KEY_IOS=
EXPO_PUBLIC_RC_API_KEY_ANDROID=

# Set to true to skip all RevenueCat calls and treat every user as Professional.
# Use this in Expo Go / CI — IAP does not work outside a native build.
EXPO_PUBLIC_BYPASS_PAYWALL=false
