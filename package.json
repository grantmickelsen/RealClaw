{
  "name": "claw",
  "version": "1.0.0",
  "description": "RealEstate OpenClaw Executive Assistant",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/mobile",
    "packages/types"
  ],
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "dev:infra": "docker compose up -d postgres claw_db redis browser manifest && tsx watch src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:e2e": "vitest run tests/e2e",
    "lint": "tsc --noEmit",
    "setup": "tsx src/setup/cli.ts",
    "migrate": "tsx src/db/migrate.ts",
    "sync-types": "cp src/types/messages.ts packages/types/src/messages.ts && cp src/types/agents.ts packages/types/src/agents.ts && cp src/types/integrations.ts packages/types/src/integrations.ts && cp src/types/events.ts packages/types/src/events.ts && cp src/types/ws.ts packages/types/src/ws.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.52.0",
    "@clack/prompts": "^1.2.0",
    "@google/generative-ai": "^0.21.0",
    "@slack/bolt": "^4.1.0",
    "@types/ioredis": "^4.28.10",
    "@types/ws": "^8.18.1",
    "@whiskeysockets/baileys": "^6.7.0",
    "bullmq": "^5.73.5",
    "discord.js": "^14.16.0",
    "dotenv": "^16.4.0",
    "expo-server-sdk": "^6.1.0",
    "googleapis": "^144.0.0",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3",
    "node-cron": "^3.0.0",
    "node-fetch": "^3.3.0",
    "open": "^11.0.0",
    "openai": "^4.73.0",
    "pg": "^8.20.0",
    "puppeteer-core": "^23.0.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "uuid": "^10.0.0",
    "winston": "^3.14.0",
    "ws": "^8.20.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.0.0",
    "@types/node-cron": "^3.0.0",
    "@types/pg": "^8.20.0",
    "@types/uuid": "^10.0.0",
    "@vitest/coverage-v8": "^2.1.0",
    "msw": "^2.6.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
