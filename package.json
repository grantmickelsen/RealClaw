{
  "name": "claw",
  "version": "1.0.0",
  "description": "RealEstate OpenClaw Executive Assistant",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:e2e": "vitest run tests/e2e",
    "lint": "tsc --noEmit",
    "setup": "tsx src/setup/cli.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.52.0",
    "@clack/prompts": "^1.2.0",
    "@google/generative-ai": "^0.21.0",
    "@slack/bolt": "^4.1.0",
    "@whiskeysockets/baileys": "^6.7.0",
    "discord.js": "^14.16.0",
    "dotenv": "^16.4.0",
    "googleapis": "^144.0.0",
    "node-cron": "^3.0.0",
    "node-fetch": "^3.3.0",
    "open": "^11.0.0",
    "openai": "^4.73.0",
    "puppeteer-core": "^23.0.0",
    "uuid": "^10.0.0",
    "winston": "^3.14.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/node-cron": "^3.0.0",
    "@types/uuid": "^10.0.0",
    "@vitest/coverage-v8": "^2.1.0",
    "msw": "^2.6.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
