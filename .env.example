# ─── OpenClaw Gateway ───
OPENCLAW_GATEWAY_PORT=18789
OPENCLAW_LOG_LEVEL=info

# ─── Manifest — Smart LLM Router (recommended) ───────────────────────────────
# Manifest automatically routes requests to the cheapest capable model from
# your configured providers. See https://manifest.build for details.
#
# Setup: docker compose up -d manifest postgres
#        Open http://localhost:3001 → add your provider keys → create an agent
#        Copy the agent API key (mnfst_…) below.
CLAW_MANIFEST_API_KEY=
# Override if running Manifest outside Docker (default: http://manifest:3001)
CLAW_MANIFEST_ENDPOINT=http://manifest:3001
# Secret for Manifest's auth system — generate with: openssl rand -hex 32
MANIFEST_AUTH_SECRET= 

# ─── LLM Providers (configure one or more) ───
# These are only needed when NOT using Manifest, or as fallback when Manifest
# is unavailable. When using Manifest, configure provider keys in its dashboard
# at http://localhost:3001 instead — they never need to live in this file.

# Anthropic (cloud)
CLAW_ANTHROPIC_API_KEY=
# OpenAI (cloud)
CLAW_OPENAI_API_KEY=
# Google Gemini (cloud)
CLAW_GOOGLE_API_KEY=
# OpenRouter (cloud, multi-provider gateway)
CLAW_OPENROUTER_API_KEY=
# Ollama (local — no API key needed)
CLAW_OLLAMA_HOST=127.0.0.1
CLAW_OLLAMA_PORT=11434

# ─── Messaging Platform (configure one primary) ───
CLAW_PRIMARY_PLATFORM=discord
CLAW_DISCORD_BOT_TOKEN=
CLAW_DISCORD_CHANNEL_ID=
CLAW_SLACK_BOT_TOKEN=
CLAW_SLACK_APP_TOKEN=
CLAW_SLACK_CHANNEL_ID=
CLAW_WHATSAPP_SESSION_PATH=./whatsapp-session

# ─── Email ───
CLAW_EMAIL_PROVIDER=gmail
CLAW_GMAIL_CLIENT_ID=
CLAW_GMAIL_CLIENT_SECRET=
CLAW_GMAIL_REDIRECT_URI=http://localhost:3000/oauth/gmail/callback
CLAW_GMAIL_REFRESH_TOKEN=

# ─── Calendar ───
CLAW_CALENDAR_PROVIDER=google_calendar
# (shares Gmail OAuth if same Google account)

# ─── CRM ───
CLAW_CRM_PROVIDER=hubspot
CLAW_HUBSPOT_ACCESS_TOKEN=
CLAW_HUBSPOT_REFRESH_TOKEN=

# ─── SMS ───
CLAW_TWILIO_ACCOUNT_SID=
CLAW_TWILIO_AUTH_TOKEN=
CLAW_TWILIO_PHONE_NUMBER=

# ─── Cloud Storage ───
CLAW_STORAGE_PROVIDER=google_drive
# (shares Gmail OAuth if same Google account)

# ─── Design ───
CLAW_CANVA_ACCESS_TOKEN=

# ─── Social ───
CLAW_BUFFER_ACCESS_TOKEN=

# ─── MLS / Listing Data ───
# RentCast — free tier (50 calls/mo) at https://rentcast.io, paid from $19/mo
# Powers comp analysis, market stats, active listings in the Research agent.
CLAW_RENTCAST_API_KEY=
# Your primary farm area zip code — used in daily briefing market snapshot
CLAW_PRIMARY_ZIP=

# Future: ATTOM Data (deed-based comps, no MLS required) — https://www.attomdata.com
# CLAW_ATTOM_API_KEY=

# Future: CoreLogic Trestle RESO Web API (full CRMLS feed, requires broker affiliation)
# CLAW_TRESTLE_CLIENT_ID=
# CLAW_TRESTLE_CLIENT_SECRET=

# Legacy CRMLS RETS (deprecated — use Trestle instead)
# CLAW_CRMLS_USERNAME=
# CLAW_CRMLS_PASSWORD=
# CLAW_CRMLS_SERVER_URL=

# ─── Document Signing ───
CLAW_DOCUSIGN_INTEGRATION_KEY=
CLAW_DOCUSIGN_SECRET_KEY=
CLAW_DOCUSIGN_ACCOUNT_ID=

# ─── Virtual Staging ───
CLAW_VIRTUAL_STAGING_API_KEY=

# ─── Monitoring ───
CLAW_ADMIN_SLACK_WEBHOOK=https://hooks.slack.com/services/xxx
CLAW_ADMIN_ALERT_CHANNEL=#claw-alerts

# ─── Security ───
CLAW_VAULT_MASTER_KEY=
CLAW_CREDENTIAL_ROTATION_DAYS=90

# ─── Authentication ───
# Generate with: openssl rand -hex 32
JWT_SECRET=
JWT_ISSUER=realclaw

# ─── Database ───
# Local dev (via docker compose): postgresql://claw:claw@localhost:5432/realclaw
# Production: set to your managed PostgreSQL connection string
DATABASE_URL=postgresql://claw:claw@localhost:5432/realclaw

# ─── Redis ───
# Local dev (via docker compose): redis://localhost:6379
REDIS_URL=redis://localhost:6379

# ─── Infrastructure ───
CLAW_MEMORY_PATH=/opt/claw/memory
CLAW_BACKUP_PATH=/opt/claw/backups
CLAW_BACKUP_SCHEDULE=0 3 * * *
NODE_ENV=production
